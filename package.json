{
  "name": "seichi-portal-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "fmt": "prettier --check --log-level=warn './**/*.{ts,tsx,css}'",
    "fmt:fix": "prettier --write --log-level=warn './**/*.{ts,tsx,css}'",
    "pretty": "pnpm lint:fix && pnpm fmt:fix && pnpm build",
    "type-check": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:component && pnpm test:e2e",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:e2e": "playwright test",
    "codegen": "tsx scripts/codegen.ts",
    "codegen:check": "tsx scripts/codegen.ts && git diff --exit-code src/generated"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.28.1",
    "@azure/msal-react": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/cache": "^11.11.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^5.0.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/material-nextjs": "^9.0.0",
    "@mui/x-data-grid": "^9.0.0",
    "@mui/x-date-pickers": "^9.6.0",
    "browserslist": "^4.23.0",
    "dayjs": "^1.11.9",
    "fp-ts": "^2.16.8",
    "next": "^16",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.45.4",
    "react-markdown": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "swr": "^2.2.5",
    "ts-pattern": "^5.6.2",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.1.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/strictest": "^2.0.1",
    "@types/eslint": "9.6.1",
    "@types/eslint-config-prettier": "^6.11.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "^16",
    "eslint-config-prettier": "^10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.5",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.0.1",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.1.9"
  }
}
